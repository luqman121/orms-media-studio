{
  "name": "orms-media-studio",
  "private": true,
  "version": "2.0.0",
  "description": "OpenRouter Media Studio — scalable Next.js monorepo (web + worker + shared packages)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "prisma generate --schema=packages/db/prisma/schema.prisma || true",
    "generate": "npm --workspace @orms/db run generate",
    "dev": "npm run generate && npm --workspace apps/web run dev",
    "build": "npm run generate && npm --workspace apps/web run build",
    "start": "npm --workspace apps/web run start",
    "lint": "npm --workspace apps/web run lint",
    "migrate": "npm --workspace @orms/db run migrate",
    "migrate:deploy": "npm --workspace @orms/db run migrate:deploy",
    "db:seed-from-sqlite": "tsx scripts/migrate-sqlite-to-pg.ts",
    "worker:dev": "npm --workspace apps/worker run dev",
    "icons": "node scripts/generate-icons.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  },
  "dependencies": {
    "motion": "^12.42.2"
  }
}
