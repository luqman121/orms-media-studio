# OpenRouter API — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# JWT secret — generate with: python3 -c "import secrets;print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-hex-string

# Optional
# APP_REFERER=http://localhost:3001
# APP_TITLE=OpenRouter Media Studio
# PORT=3001
# CORS_ORIGIN — comma-separated allowlist for production (e.g. https://your-app.vercel.app)
#               leave unset to allow all origins (dev default)
# CORS_ORIGIN=https://your-app.vercel.app

# ===== Next.js migration (apps/web) =====
# Phase 1: the Next.js dev server (:3000) proxies /api/* to the Express backend.
# BACKEND_ORIGIN=http://localhost:3001

# ===== Phase 3+ (packages/db, apps/worker) — not required for Phase 1 =====
# PostgreSQL connection string (Neon). Used by Prisma once the DB migration lands.
# DATABASE_URL=postgresql://user:password@host/db?sslmode=require
# Redis URL for BullMQ queue + model-list cache (Phase 5).
# REDIS_URL=redis://localhost:6379