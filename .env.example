# OpenRouter API — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# JWT secret — generate with: python3 -c "import secrets;print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-hex-string

# Optional
# APP_REFERER=http://localhost:3001
# APP_TITLE=OpenRouter Media Studio
# PORT=3001
# CORS_ORIGIN — comma-separated allowlist for production (e.g. https://your-app.vercel.app)
#               leave unset to allow all origins (dev default)
# CORS_ORIGIN=https://your-app.vercel.app

# ===== Database (Prisma / PostgreSQL) — REQUIRED =====
# Neon/Supabase/any Postgres. Used by Prisma (@orms/db) and the app at runtime.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Data dir for uploads + generated assets (local disk until Phase 4 → R2).
# DATA_DIR=./data

# ===== Phase 5 (apps/worker) — not required yet =====
# Redis URL for the BullMQ video-poll queue.
# REDIS_URL=redis://localhost:6379