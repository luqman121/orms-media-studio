# OpenRouter API — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# JWT secret — generate with: python3 -c "import secrets;print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-hex-string

# Optional
# APP_REFERER=http://localhost:3001
# APP_TITLE=OpenRouter Media Studio
# PORT=3001

# ===== Database (Prisma / PostgreSQL) — REQUIRED =====
# Neon/Supabase/any Postgres. On Supabase use the IPv4 session-pooler host.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ===== Cloudflare R2 (Phase 4) — REQUIRED for asset storage =====
# Create an R2 bucket, then generate an API token (Object Read & Write) in the
# Cloudflare dashboard → R2 → Manage R2 API Tokens.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=orms-assets

# ===== Phase 5 (apps/worker) — not required yet =====
# Redis URL for the BullMQ video-poll queue.
# REDIS_URL=redis://localhost:6379
